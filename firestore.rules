rules_version = '2';

// Training Book security rules — MULTI-USER.
//
// Every signed-in person (Daniel, his wife, anyone who signs in with their own
// Google account) gets a private space at users/{their uid}. These rules let a
// signed-in user read and write ONLY their own document and their own version-
// history backups subcollection — never anyone else's. No sign-in = no access.
//
// HOW TO APPLY (one time, ~1 minute):
//   1. Firebase console → project "training-book-6c456" → Build → Firestore
//      Database → Rules tab.
//   2. Replace whatever is there with the contents of this file.
//   3. Press Publish.
// If the existing rules already say `request.auth.uid == userId` (generic, not a
// hard-coded uid), they already support multiple users and this just confirms it.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's main data document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // That user's rolling version-history snapshots.
      match /backups/{backupId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Everything else is denied by default.
  }
}
